<!-- This is Boilerplate Template -->
<% layout("/layouts/boilerplate") -%>
<body>
  <div class="row offset-3">
    <!-- <div class="col-2 border">
      <p>Testing the effect of col-x class</p>
    </div> -->
    <div class="col-8">
      <br />
      <h3>Create your Listing</h3>
      <form
        method="POST"
        action="/listings"
        novalidate
        class="needs-validation"
      >
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            name="listing[title]"
            placeholder="Enter title"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter the title</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listing[description]"
            placeholder="Enter description"
            class="form-control"
            id=""
            required
          ></textarea>
          <div class="invalid-feedback">This is required</div>
        </div>

        <div class="mb-3">
          <label for="image_name" class="form-label">Image Name</label>
          <input
            name="listing[image][filename]"
            placeholder="Enter filename"
            type="text"
            class="form-control"
          />
          <br />
          <label for="image_url" class="form-label">Image URL</label>
          <input
            name="listing[image][url]"
            placeholder="Enter image URL"
            type="text"
            class="form-control"
          />
          <div class="invalid-feedback">This is required</div>
        </div>

        <div class="row">
          <!-- Takes 8 columns on medium+ screens, full width on smaller screens -->
          <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input
              name="listing[price]"
              placeholder="Enter price"
              type=""
              class="form-control"
              required
            />
            <div class="invalid-feedback">Please enter the valid Price</div>
          </div>

          <!-- Takes 8 columns on medium+ screens, full width on smaller screens -->
          <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input
              name="listing[country]"
              placeholder="Enter country name"
              type="text"
              class="form-control"
              required
            />
            <div class="invalid-feedback">
              Please enter the valid name of country
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            placeholder="Enter location"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Enter the valid Location</div>
        </div>
        <button class="btn btn-dark mb-3">Add</button>
      </form>
    </div>
  </div>
</body>
