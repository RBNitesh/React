<!-- This is Boilerplate Template -->
<% layout("/layouts/boilerplate") -%>
<body>
  <div class="row">
    <div class="col-8 offset-3 mt-3">
      <h3><%= listing.title %></h3>
    </div>
    <div class="card listing-card show-img col-6 offset-3">
      <img
        src="<%= listing.image && listing.image.url ? listing.image.url : '' %>"
        class="card-img-top"
        alt="listing_image"
      />
      <div class="card-body">
        <%= listing.description %> <br />
        &#x20B9; <%=listing.price.toLocaleString("en-IN") %> <br />
        <%= listing.location %> <br />
        <%= listing.country %>
      </div>
    </div>
    <div class="btns mb-2">
      <a
        href="/listings/<%= listing._id %>/edit"
        class="btn edit-btn col-1 offset-3"
        >Edit</a
      >
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn delete-btn offset-5">Delete</button>
      </form>
    </div>
    <div class="col-8 offset-3 mb-2">
      <hr />
      <h4>Leave a Review</h4>
      <form
        action="/listings/<%= listing.id %>/reviews"
        method="POST"
        novalidate
        class="needs-validation"
      >
        <div class="mb-2 mt-2">
          <label for="rating" class="form-label">Rating</label>
          <input
            type="range"
            min="1"
            max="5"
            id="rating"
            name="review[rating]"
            class="form-range"
          />
        </div>
        <div class="mb-2 mt-2">
          <label for="comment" class="form-label">Comments</label>
          <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            rows="5"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">
            Please submit some comment for reviews
          </div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
      </form>
      <hr />
    <h4>All Reviews</h4>
      <ul>
        <!-- Populate in show route before this -->
         <div class = "row">
          <% for(review of listing.reviews){ %>
            <div class="card col-5 mb-3 ms-3">
              <div class="card-body">
                <h5 class="card-title">Card title</h5>
                <p class="card-text"><%= review.comment %></p>
                <p class = "card-text"><%= review.rating %></p>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="POST">
                  <button class="btn">Delete</button>
                </form>
              </div>
            </div>
          <%} %>
         </div>
      </ul>
    </div>
  </div>
</body>
