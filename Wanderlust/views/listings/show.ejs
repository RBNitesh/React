<!-- This is Boilerplate Template -->
<% layout("/layouts/boilerplate") -%>
<body>
  <div class="row">
    <div class="col-8 offset-3 mt-3">
      <h3>Listing Details</h3>
    </div>
    <div class="card show-img col-6 offset-3">
      <img
        src="<%= listing.image && listing.image.url ? listing.image.url : '' %>"
        class="card-img-top"
        alt="listing_image"
      />
      <div class="card-body">
        <b><%= listing.title %></b><br />
        <%= listing.description %> <br />
        &#x20B9; <%=listing.price.toLocaleString("en-IN") %> <br />
        <%= listing.location %> <br />
        <%= listing.country %>
      </div>
    </div>
  </div>
</body>
<div class="btns mb-2">
  <a
    href="/listings/<%= listing._id %>/edit"
    class="btn edit-btn col-1 offset-3"
    >Edit</a
  >
  <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button class="btn delete-btn offset-5">Delete</button>
  </form>
</div>
